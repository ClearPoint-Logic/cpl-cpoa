# ClearPoint Onboarding Agent — environment contract (§17.1)
# Copy to .env and fill in. NEVER commit .env.

# --- Google Cloud / Vertex AI ---------------------------------------------
# BINDING RULE: Gemini must run via Vertex AI. "Gemini on Google AI Studio is
# NOT available for credit usage" (official rules). Do not use an AI Studio key.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=clearpoint-operations-agent
GOOGLE_CLOUD_LOCATION=us-central1
# Leave blank to use Application Default Credentials (gcloud auth application-default login).
# Set to a key path only for deployed/non-ADC contexts.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Model selection (configure; do not hardcode unstable names — CPOA-D006) ---
CPL_GEMINI_MODEL=gemini-2.5-pro
CPL_GEMINI_MODEL_FAST=gemini-2.5-flash

# --- Storage backend ---
CPOA_STORAGE_MODE=local              # local | firestore | cloudsql

# --- Evidence signing (CPOA-D010 / FR-053) ---
CPOA_DEMO_SIGNATURE_MODE=stub        # stub | sigstore

# --- Grounding backend (CPOA-D020 / FR-081/082) ---
CPOA_GROUNDING_MODE=local            # local | vertex_ai_search
CPOA_VERTEX_SEARCH_DATASTORE=        # data store id when CPOA_GROUNDING_MODE=vertex_ai_search

# --- Judge access: HTTP basic auth for deployed Web UI (CPOA-D026 / FR-076) ---
CPOA_JUDGE_BASIC_AUTH_USER=
CPOA_JUDGE_BASIC_AUTH_PASS=

# --- Secure MCP server (§12.6) ---
CPOA_MCP_BASE_URL=http://localhost:8081
CPOA_MCP_AUTH_TOKEN=                 # bearer token required by deployed MCP server (FR-090)
