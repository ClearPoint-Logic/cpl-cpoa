# Next.js judge UI (standalone). Build context = repo root.
FROM node:22-slim@sha256:32b9e321f262db540d55ac10dc529667cf4737546e097cdd36a843c62bcbf423 AS build
WORKDIR /app
COPY app/web/package.json app/web/package-lock.json ./
RUN npm ci
COPY app/web ./
# Bake the API base into the build so next.config rewrites resolve to the API service.
ARG CPOA_API_BASE=http://localhost:8080
ENV CPOA_API_BASE=${CPOA_API_BASE}
# Bake judge basic-auth creds so the Edge middleware inlines them at build time.
ARG CPOA_JUDGE_BASIC_AUTH_USER=""
ARG CPOA_JUDGE_BASIC_AUTH_PASS=""
ENV CPOA_JUDGE_BASIC_AUTH_USER=${CPOA_JUDGE_BASIC_AUTH_USER}
ENV CPOA_JUDGE_BASIC_AUTH_PASS=${CPOA_JUDGE_BASIC_AUTH_PASS}
RUN npm run build

FROM node:22-slim@sha256:32b9e321f262db540d55ac10dc529667cf4737546e097cdd36a843c62bcbf423 AS run
WORKDIR /app
ENV NODE_ENV=production HOSTNAME=0.0.0.0 PORT=8080
# Re-declare so the running server's rewrites() also see it.
ARG CPOA_API_BASE=http://localhost:8080
ENV CPOA_API_BASE=${CPOA_API_BASE}
COPY --from=build /app/.next/standalone ./
COPY --from=build /app/.next/static ./.next/static
COPY --from=build /app/public ./public
EXPOSE 8080
CMD ["node", "server.js"]
